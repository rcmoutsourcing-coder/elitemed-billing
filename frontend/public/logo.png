  font-family: "Inter", sans-serif;
  line-height: 16px;
}
pwa-extension-ng-components .pwa-label-medium-md {
  font-size: 14px;
  letter-spacing: 0.2px;
  font-weight: 500;
  font-family: "Inter", sans-serif;
  line-height: 20px;
}
pwa-extension-ng-components .pwa-label-large-md {
  font-size: 16px;
