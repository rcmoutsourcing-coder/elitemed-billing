17335-54 mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered=""><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c3933017335="" role="img" fonticon="download" class="mat-icon notranslate gds-icon-s google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="download"></mat-icon><!----><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----><!----><!----><!----><button _ngcontent-ng-c3933017335="" aria-label="Copy code" mat-icon-button="" mattooltip="Copy code" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c3933017335-54 mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_86e38ac938d6308b&quot;,&quot;c_bacbcc7396081285&quot;,null,&quot;rc_20a46c112ef5fe2d&quot;,null,null,&quot;&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c3933017335="" role="img" fonticon="content_copy" class="mat-icon notranslate gds-icon-s google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><!----><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----><!----></div><!----><!----></div><!----><div _ngcontent-ng-c3933017335="" class="formatted-code-block-internal-container ng-tns-c3933017335-54"><div _ngcontent-ng-c3933017335="" class="animated-opacity ng-tns-c3933017335-54"><!----><pre _ngcontent-ng-c3933017335="" class="ng-tns-c3933017335-54"><code _ngcontent-ng-c3933017335="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c3933017335-54"><span class="hljs-comment">// backend/models/Service.js</span>
<span class="hljs-keyword">const</span> mongoose = <span class="hljs-built_in">require</span>(<span class="hljs-string">'mongoose'</span>);

<span class="hljs-keyword">const</span> ServiceSchema = <span class="hljs-keyword">new</span> mongoose.Schema({
  <span class="hljs-attr">title</span>: { <span class="hljs-attr">type</span>: <span class="hljs-built_in">String</span>, <span class="hljs-attr">required</span>: <span class="hljs-literal">true</span> },
  <span class="hljs-attr">description</span>: { <span class="hljs-attr">type</span>: <span class="hljs-built_in">String</span>, <span class="hljs-attr">required</span>: <span class="hljs-literal">true</span> },
  <span class="hljs-attr">icon</span>: { <span class="hljs-attr">type</span>: <span class="hljs-built_in">String</span>, <span class="hljs-attr">default</span>: <span class="hljs-string">'Activity'</span> }, <span class="hljs-comment">// Lucide icon name</span>
  <span class="hljs-attr">slug</span>: { <span class="hljs-attr">type</span>: <span class="hljs-built_in">String</span>, <span class="hljs-attr">unique</span>: <span class="hljs-literal">true</span> },
  <span class="hljs-attr">order</span>: { <span class="hljs-attr">type</span>: <span class="hljs-built_in">Number</span>, <span class="hljs-attr">default</span>: <span class="hljs-number">0</span> }
});

<span class="hljs-built_in">module</span>.exports = mongoose.model(<span class="hljs-string">'Service'</span>, ServiceSchema);

<span class="hljs-comment">// backend/models/Lead.js</span>
<span class="hljs-keyword">const</span> LeadSchema = <span class="hljs-keyword">new</span> mongoose.Schema({
  <span class="hljs-attr">name</span>: <span class="hljs-built_in">String</span>,
  <span class="hljs-attr">email</span>: <span class="hljs-built_in">String</span>,
  <span class="hljs-attr">phone</span>: <span class="hljs-built_in">String</span>,
  <span class="hljs-attr">message</span>: <span class="hljs-built_in">String</span>,
  <span class="hljs-attr">status</span>: { <span class="hljs-attr">type</span>: <span class="hljs-built_in">String</span>, <span class="hljs-attr">default</span>: <span class="hljs-string">'New'</span> }, <span class="hljs-comment">// New, In Progress, Closed</span>
  <span class="hljs-attr">createdAt</span>: { <span class="hljs-attr">type</span>: <span class="hljs-built_in">Date</span>, <span class="hljs-attr">default</span>: <span class="hljs-built_in">Date</span>.now }
});

<span class="hljs-built_in">module</span>.exports = mongoose.model(<span class="hljs-string">'Lead'</span>, LeadSchema);
</code></pre><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><hr data-path-to-node="8"><h2 data-path-to-node="9">2. Frontend: Dynamic CMS Integration (Next.js)</h2><p data-path-to-node="10">The Home Page fetches content from the API. This ensures "EliteMedBilling" staff can change headlines without touching code.</p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c3933017335="" class="ng-tns-c3933017335-55 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c3933017335="" class="code-block ng-tns-c3933017335-55 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression,attention;BardVeMetadataKey:[[&quot;r_86e38ac938d6308b&quot;,&quot;c_bacbcc7396081285&quot;,null,&quot;rc_20a46c112ef5fe2d&quot;,null,null,&quot;&quot;,null,1,null,null,1,0]]" data-hveid="0" decode-data-ved="1" data-ved="0CAAQhtANahcKEwiD7sa47-qTAxUAAAAAHQAAAAAQXA" style="display: block;"><div _ngcontent-ng-c3933017335="" class="code-block-decoration header-formatted gds-title-s ng-tns-c3933017335-55 ng-star-inserted" style=""><span _ngcontent-ng-c3933017335="" class="ng-tns-c3933017335-55">JavaScript</span><div _ngcontent-ng-c3933017335="" class="buttons ng-tns-c3933017335-55 ng-star-inserted"><button _ngcontent-ng-c3933017335="" aria-label="Download code" mat-icon-button="" mattooltip="Download code" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger download-button ng-tns-c3933017335-55 mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered=""><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c3933017335="" role="img" fonticon="download" class="mat-icon notranslate gds-icon-s google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="download"></mat-icon><!----><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----><!----><!----><!----><button _ngcontent-ng-c3933017335="" aria-label="Copy code" mat-icon-button="" mattooltip="Copy code" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c3933017335-55 mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_86e38ac938d6308b&quot;,&quot;c_bacbcc7396081285&quot;,null,&quot;rc_20a46c112ef5fe2d&quot;,null,null,&quot;&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c3933017335="" role="img" fonticon="content_copy" class="mat-icon notranslate gds-icon-s google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><!----><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----><!----></div><!----><!----></div><!----><div _ngcontent-ng-c3933017335="" class="formatted-code-block-internal-container ng-tns-c3933017335-55"><div _ngcontent-ng-c3933017335="" class="animated-opacity ng-tns-c3933017335-55"><!----><pre _ngcontent-ng-c3933017335="" class="ng-tns-c3933017335-55"><code _ngcontent-ng-c3933017335="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c3933017335-55"><span class="hljs-comment">// frontend/src/app/page.tsx</span>
<span class="hljs-keyword">import</span> Hero <span class="hljs-keyword">from</span> <span class="hljs-string">'@/components/Hero'</span>;
<span class="hljs-keyword">import</span> ServiceGrid <span class="hljs-keyword">from</span> <span class="hljs-string">'@/components/ServiceGrid'</span>;

<span class="hljs-keyword">async</span> <span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">getPageData</span>(<span class="hljs-params"></span>) </span>{
  <span class="hljs-keyword">const</span> res = <span class="hljs-keyword">await</span> fetch(<span class="hljs-string">`<span class="hljs-subst">${process.env.NEXT_PUBLIC_API_URL}</span>/content/home`</span>, { <span class="hljs-attr">next</span>: { <span class="hljs-attr">revalidate</span>: <span class="hljs-number">3600</span> } });
  <span class="hljs-keyword">return</span> res.json();
}

<span class="hljs-keyword">export</span> <span class="hljs-keyword">default</span> <span class="hljs-keyword">async</span> <span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">HomePage</span>(<span class="hljs-params"></span>) </span>{
  <span class="hljs-keyword">const</span> data = <span class="hljs-keyword">await</span> getPageData();

  <span class="hljs-keyword">return</span> (
    <span class="xml"><span class="hljs-tag">&lt;<span class="hljs-name">main</span>&gt;</span>
      <span class="hljs-tag">&lt;<span class="hljs-name">Hero</span> 
        <span class="hljs-attr">title</span>=<span class="hljs-string">{data.heroTitle</span> || "<span class="hljs-attr">Elite</span> <span class="hljs-attr">Revenue</span> <span class="hljs-attr">Cycle</span> <span class="hljs-attr">Management</span>"}
        <span class="hljs-attr">subtitle</span>=<span class="hljs-string">{data.heroSubtitle</span> || "<span class="hljs-attr">Maximizing</span> <span class="hljs-attr">collections</span> <span class="hljs-attr">for</span> <span class="hljs-attr">US</span> <span class="hljs-attr">healthcare</span> <span class="hljs-attr">providers.</span>"}
        <span class="hljs-attr">ctaText</span>=<span class="hljs-string">{data.heroBtn}</span>
      /&gt;</span>
      
      <span class="hljs-tag">&lt;<span class="hljs-name">section</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"py-20 bg-white"</span>&gt;</span>
        <span class="hljs-tag">&lt;<span class="hljs-name">div</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"container mx-auto px-6"</span>&gt;</span>
