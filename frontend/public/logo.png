c-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c3933017335-159 mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_226342419a9267be&quot;,&quot;c_bacbcc7396081285&quot;,null,&quot;rc_772ced8e1d465f0d&quot;,null,null,&quot;&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c3933017335="" role="img" fonticon="content_copy" class="mat-icon notranslate gds-icon-s google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><!----><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----><!----></div><!----><!----></div><!----><div _ngcontent-ng-c3933017335="" class="formatted-code-block-internal-container ng-tns-c3933017335-159"><div _ngcontent-ng-c3933017335="" class="animated-opacity ng-tns-c3933017335-159"><!----><pre _ngcontent-ng-c3933017335="" class="ng-tns-c3933017335-159"><code _ngcontent-ng-c3933017335="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c3933017335-159"><span class="hljs-keyword">const</span> express = <span class="hljs-built_in">require</span>(<span class="hljs-string">'express'</span>);
<span class="hljs-keyword">const</span> mongoose = <span class="hljs-built_in">require</span>(<span class="hljs-string">'mongoose'</span>);
<span class="hljs-keyword">const</span> cors = <span class="hljs-built_in">require</span>(<span class="hljs-string">'cors'</span>);
<span class="hljs-built_in">require</span>(<span class="hljs-string">'dotenv'</span>).config();

<span class="hljs-keyword">const</span> app = express();
app.use(cors());
app.use(express.json());

mongoose.connect(process.env.MONGODB_URI)
  .then(<span class="hljs-function">() =&gt;</span> <span class="hljs-built_in">console</span>.log(<span class="hljs-string">"EliteMed Database Connected"</span>))
  .catch(<span class="hljs-function"><span class="hljs-params">err</span> =&gt;</span> <span class="hljs-built_in">console</span>.log(err));

<span class="hljs-keyword">const</span> PostSchema = <span class="hljs-keyword">new</span> mongoose.Schema({
  <span class="hljs-attr">title</span>: <span class="hljs-built_in">String</span>,
  <span class="hljs-attr">content</span>: <span class="hljs-built_in">String</span>,
  <span class="hljs-attr">image</span>: <span class="hljs-built_in">String</span>,
  <span class="hljs-attr">createdAt</span>: { <span class="hljs-attr">type</span>: <span class="hljs-built_in">Date</span>, <span class="hljs-attr">default</span>: <span class="hljs-built_in">Date</span>.now }
});
<span class="hljs-keyword">const</span> Post = mongoose.model(<span class="hljs-string">'Post'</span>, PostSchema);

app.get(<span class="hljs-string">'/api/posts'</span>, <span class="hljs-keyword">async</span> (req, res) =&gt; {
  <span class="hljs-keyword">const</span> posts = <span class="hljs-keyword">await</span> Post.find().sort({ <span class="hljs-attr">createdAt</span>: -<span class="hljs-number">1</span> });
  res.json(posts);
});

app.post(<span class="hljs-string">'/api/posts'</span>, <span class="hljs-keyword">async</span> (req, res) =&gt; {
  <span class="hljs-keyword">const</span> newPost = <span class="hljs-keyword">new</span> Post(req.body);
  <span class="hljs-keyword">await</span> newPost.save();
  res.json({ <span class="hljs-attr">message</span>: <span class="hljs-string">"Post Created!"</span> });
});

<span class="hljs-keyword">const</span> PORT = process.env.PORT || <span class="hljs-number">5000</span>;
app.listen(PORT, <span class="hljs-function">() =&gt;</span> <span class="hljs-built_in">console</span>.log(<span class="hljs-string">`Server running on <span class="hljs-subst">${PORT}</span>`</span>));
</code></pre><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><p data-path-to-node="9"><b data-path-to-node="9" data-index-in-node="0">File 3: <code data-path-to-node="9" data-index-in-node="8">backend/.env</code></b>
