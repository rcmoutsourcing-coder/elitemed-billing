 mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger download-button ng-tns-c3933017335-56 mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered=""><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c3933017335="" role="img" fonticon="download" class="mat-icon notranslate gds-icon-s google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="download"></mat-icon><!----><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----><!----><!----><!----><button _ngcontent-ng-c3933017335="" aria-label="Copy code" mat-icon-button="" mattooltip="Copy code" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button ng-tns-c3933017335-56 mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="179062;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_86e38ac938d6308b&quot;,&quot;c_bacbcc7396081285&quot;,null,&quot;rc_20a46c112ef5fe2d&quot;,null,null,&quot;&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c3933017335="" role="img" fonticon="content_copy" class="mat-icon notranslate gds-icon-s google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><!----><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----><!----></div><!----><!----></div><!----><div _ngcontent-ng-c3933017335="" class="formatted-code-block-internal-container ng-tns-c3933017335-56"><div _ngcontent-ng-c3933017335="" class="animated-opacity ng-tns-c3933017335-56"><!----><pre _ngcontent-ng-c3933017335="" class="ng-tns-c3933017335-56"><code _ngcontent-ng-c3933017335="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c3933017335-56"><span class="hljs-comment">// frontend/src/app/admin/services/page.tsx</span>
<span class="hljs-string">'use client'</span>;
<span class="hljs-keyword">import</span> { useState, useEffect } <span class="hljs-keyword">from</span> <span class="hljs-string">'react'</span>;
<span class="hljs-keyword">import</span> axios <span class="hljs-keyword">from</span> <span class="hljs-string">'@/lib/axios'</span>;

<span class="hljs-keyword">export</span> <span class="hljs-keyword">default</span> <span class="hljs-function"><span class="hljs-keyword">function</span> <span class="hljs-title">ManageServices</span>(<span class="hljs-params"></span>) </span>{
  <span class="hljs-keyword">const</span> [services, setServices] = useState([]);

  <span class="hljs-keyword">const</span> handleDelete = <span class="hljs-keyword">async</span> (id) =&gt; {
    <span class="hljs-keyword">await</span> axios.delete(<span class="hljs-string">`/api/services/<span class="hljs-subst">${id}</span>`</span>);
    setServices(services.filter(<span class="hljs-function"><span class="hljs-params">s</span> =&gt;</span> s._id !== id));
  };

  <span class="hljs-keyword">return</span> (
    <span class="xml"><span class="hljs-tag">&lt;<span class="hljs-name">div</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"p-8"</span>&gt;</span>
      <span class="hljs-tag">&lt;<span class="hljs-name">div</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"flex justify-between mb-6"</span>&gt;</span>
        <span class="hljs-tag">&lt;<span class="hljs-name">h1</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"text-2xl font-bold"</span>&gt;</span>Manage Services<span class="hljs-tag">&lt;/<span class="hljs-name">h1</span>&gt;</span>
        <span class="hljs-tag">&lt;<span class="hljs-name">button</span> <span class="hljs-attr">className</span>=<span class="hljs-string">"bg-[#0EA5E9] text-white px-4 py-2 rounded"</span>&gt;</span>Add Service<span class="hljs-tag">&lt;/<span class="hljs-name">button</span>&gt;</span>
      <span class="hljs-tag">&lt;/<span class="hljs-name">div</span>&gt;</span>
      {/* Table with Edit/Delete actions */}
    <span class="hljs-tag">&lt;/<span class="hljs-name">div</span>&gt;</span></span>
  );
}
</code></pre><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><hr data-path-to-node="16"><h2 data-path-to-node="17">4. Deployment Steps</h2><h3 data-path-to-node="18"><b data-path-to-node="18" data-index-in-node="0">Step 1: MongoDB Atlas</b></h3><ol start="1" data-path-to-node="19"><li><p data-path-to-node="19,0,0">Create a cluster at <response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><link-block _nghost-ng-c4057496317="" class="ng-star-inserted"><!----><!----><a _ngcontent-ng-c4057496317="" target="_blank" rel="noopener" externallink="" _nghost-ng-c1676480764="" jslog="197247;track:generic_click,impression,attention;BardVeMetadataKey:[[&quot;r_86e38ac938d6308b&quot;,&quot;c_bacbcc7396081285&quot;,null,&quot;rc_20a46c112ef5fe2d&quot;,null,null,&quot;&quot;,null,1,null,null,1,0]]" href="https://www.mongodb.com/cloud/atlas" class="ng-star-inserted" data-hveid="0" decode-data-ved="1" data-ved="0CAAQ_4QMahcKEwiD7sa47-qTAxUAAAAAHQAAAAAQXg">MongoDB Atlas</a><!----></link-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element>.</p></li><li><p data-path-to-node="19,1,0">Get your <code data-path-to-node="19,1,0" data-index-in-node="9">MONGODB_URI</code>.</p></li></ol><h3 data-path-to-node="20"><b data-path-to-node="20" data-index-in-node="0">Step 2: Environment Variables (<code data-path-to-node="20" data-index-in-node="31">.env</code>)</b></h3><p data-path-to-node="21">Create this in the root folder:</p><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><code-block _nghost-ng-c3933017335="" class="ng-tns-c3933017335-57 ng-star-inserted" style=""><!----><!----><div _ngcontent-ng-c3933017335="" class="code-block ng-tns-c3933017335-57 ng-animate-disabled ng-trigger ng-trigger-codeBlockRevealAnimation" jslog="223238;track:impression,attention;BardVeMetadataKey:[[&quot;r_86e38ac938d6308b&quot;,&quot;c_bacbcc7396081285&quot;,null,&quot;rc_20a46c112ef5fe2d&quot;,null,null,&quot;&quot;,null,1,null,null,1,0]]" data-hveid="0" decode-data-ved="1" data-ved="0CAAQhtANahcKEwiD7sa47-qTAxUAAAAAHQAAAAAQXw" style="display: block;"><div _ngcontent-ng-c3933017335="" class="code-block-decoration header-formatted gds-title-s ng-tns-c3933017335-57 ng-star-inserted" style=""><span _ngcontent-ng-c3933017335="" class="ng-tns-c3933017335-57">Code snippet</span><div _ngcontent-ng-c3933017335="" class="buttons ng-tns-c3933017335-57 ng-star-inserted"><button _ngcontent-ng-c3933017335="" aria-label="Download code" mat-icon-button="" mattooltip="Download code" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger download-button ng-tns-c3933017335-57 mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered=""><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c3933017335="" role="img" fonticon="download" class="mat-icon notran