  background-color: var(--pwa-background-fill-disabled);
}
pwa-extension-ng-components .pwa-radio .radio-container input:checked ~ .checkmark:after {
  display: block;
}
pwa-extension-ng-components .pwa-radio .radio-container input:disabled ~ .checkmark {
  border-color: var(--pwa-border);
}
pwa-extension-ng-components .pwa-radio .radio-container input:disabled ~ .checkmark:after {
  background-color: var(--pwa-border);
}
pwa-extension-ng-components .pwa-radio .radio-container .checkmark {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 22px;
  width: 22px;
  box-sizing: border-box;
  border-radius: 50%;
  border: 2px solid var(--pwa-border-selected);
  background-color: var(--pwa-background);
}
pwa-extension-ng-components .pwa-radio .radio-container .checkmark:after {
  content: "";
  position: absolute;
  display: none;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background-color: var(--pwa-border-selected);
