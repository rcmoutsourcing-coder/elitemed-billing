}
pwa-extension-ng-components .pwa-label-x-small {
  font-family: "Inter", sans-serif;
  font-size: 11px;
  font-style: normal;
  font-weight: 400;
  line-height: 16px;
}
pwa-extension-ng-components .pwa-label-small {
  font-size: 12px;
  letter-spacing: 0.2px;
  font-family: "Inter", sans-serif;
  line-height: 16px;
}
pwa-extension-ng-components .pwa-label-x-small-md {
  font-family: "Inter", sans-serif;
