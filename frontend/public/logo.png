  font-weight: 600;
  font-family: "Inter", sans-serif;
  line-height: 24px;
}
pwa-extension-ng-components .shadow1 {
  box-shadow: 0 25px 35px rgba(0, 0, 0, 0.03), 0 0 5px rgba(0, 0, 0, 0.05);
}
pwa-extension-ng-components .shadow2 {
  box-shadow: 0 0 24px rgba(0, 0, 0, 0.06), 0 0 5px rgba(0, 0, 0, 0.05);
}
pwa-extension-ng-components .shadow3 {
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}
pwa-extension-ng-components .shadow4 {
  box-shadow: 0 2px 5px rgba(0, 0, 0, 0.29);
}
pwa-extension-ng-components .shadow-medium {
  box-shadow: var(--pwa-shadow-medium);
}
pwa-extension-ng-components .shadow-fx1 {
  filter: drop-shadow(0 25px 35px rgba(0, 0, 0, 0.03)) drop-shadow(0 0 5px rgba(0, 0, 0, 0.05));
}
pwa-extension-ng-components .shadow-fx2 {
  filter: drop-shadow(0 0 24px rgba(0, 0, 0, 0.06)) drop-shadow(0 0 5px rgba(0, 0, 0, 0.05));
}
pwa-extension-ng-components .shadow-fx3 {
  filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.06));
}
pwa-extension-ng-components .shadow-fx4 {
  filter: drop-shadow(0 2px 5px rgba(0, 0, 0, 0.29));
}
pwa-extension-ng-components .pwa-shadow-small {
  box-shadow: var(--pwa-shadow-small);
}
pwa-extension-ng-components .pwa-shadow-medium {
  box-shadow: var(--pwa-shadow-medium);
}
pwa-extension-ng-components .pwa-shadow-large {
  box-shadow: var(--pwa-shadow-large);
}
pwa-extension-ng-components .pwa-shadow-fx-small {
  filter: var(--pwa-shadow-fx-small);
}
pwa-extension-ng-components .pwa-shadow-fx-medium {
  filter: var(--pwa-shadow-fx-medium);
}
pwa-extension-ng-components .pwa-shadow-fx-large {
  filter: var(--pwa-shadow-fx-large);
}
pwa-extension-ng-components .pwa-btn.primary-color,
pwa-extension-ng-components .pwa-btn.main-color {
  position: relative;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  margin: 0;
  font-family: "Inter", sans-serif;
  font-weight: 600;
  border: 1px solid;
  border-radius: 6px;
  text-decoration: none;
  text-align: center;
  cursor: pointer;
  z-index: 1;
  overflow: visible;
  white-space: nowrap;
  letter-spacing: 0.02em;
  /* Buttons with icons */
  /* if you want good vertical alignment for button text and icon, wrap text into '.pwa-btn-text' */
  /* and icon into '.pwa-btn-icon' */
}
pwa-extension-ng-components .pwa-btn.primary-color .pwa-btn-content,
pwa-extension-ng-components .pwa-btn.main-color .pwa-btn-content {
  display: flex;
  align-items: center;
  flex: 1 1 auto;
  justify-content: center;
}
pwa-extension-ng-components .pwa-btn.primary-color .pwa-btn-icon,
pwa-extension-ng-components .pwa-btn.main-color .pwa-btn-icon {
  display: inline-flex;
  align-items: center;
  vertical-align: top;
  height: 100%;
  position: relative;
  flex: 0 0 auto;
}
pwa-extension-ng-components .pwa-btn.primary-color .pwa-btn-icon .pwa-icon svg,
pwa-extension-ng-components .pwa-btn.main-color .pwa-btn-icon .pwa-icon svg {
  width: 16px;
  height: 16px;
